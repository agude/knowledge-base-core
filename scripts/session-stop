#!/usr/bin/env bash
#
# session-stop - Stop hook for the knowledge base.
#
# Appends Claude's last response to the session buffer file, then flushes
# the session to an observation.
#
# Input: JSON on stdin with session_id, last_assistant_message, etc.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

# Skip if observation is disabled
[[ "${KNOWLEDGE_OBSERVE:-}" == "0" ]] && exit 0

SESSION_DIR="/tmp/knowledge-sessions"

INPUT="$(cat)"

SESSION_ID="$(echo "$INPUT" | jq -r '.session_id // empty')"
LAST_MESSAGE="$(echo "$INPUT" | jq -r '.last_assistant_message // empty')"

if [[ -z "$SESSION_ID" ]] || [[ -z "$LAST_MESSAGE" ]]; then
    exit 0
fi

SESSION_FILE="$SESSION_DIR/session-${SESSION_ID}.jsonl"

[[ -f "$SESSION_FILE" ]] || exit 0

echo "$INPUT" | jq -c '{role: "assistant", message: .last_assistant_message, timestamp: now}' \
    >> "$SESSION_FILE" 2>/dev/null || true

# Flush the session to an observation
"$SCRIPT_DIR/session-flush" "$SESSION_FILE" 2>/dev/null || true

exit 0

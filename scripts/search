#!/usr/bin/env bash
#
# search - Search knowledge and pending observations.
#
# Case-insensitive substring search across knowledge articles, source
# documents, and pending observations. Returns matching lines with
# file path and section context.
#
# Usage:
#   search <query>
#
# Options:
#   -h, --help   Show this help message
#
# Output format:
#   <relative-path> | <section heading or "top"> | <matched line trimmed>
#
# Examples:
#   search "risk arbiter"
#   search PostgreSQL

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$SCRIPT_DIR/_lib.sh"

QUERY="${1:-}"

if [[ "$QUERY" == "-h" || "$QUERY" == "--help" ]]; then
    show_help "$0"
    exit 0
fi

if [[ -z "$QUERY" ]]; then
    echo "Usage: search <query>" >&2
    exit 1
fi

SEARCH_DIRS=()
for d in "$CONTENT_DIR/knowledge" "$CONTENT_DIR/sources" "$CONTENT_DIR/observations/pending"; do
    [[ -d "$d" ]] && SEARCH_DIRS+=("$d")
done

if [[ ${#SEARCH_DIRS[@]} -eq 0 ]]; then
    echo "No content directories found." >&2
    exit 0
fi

find "${SEARCH_DIRS[@]}" \
    -name '*.md' -type f 2>/dev/null | while read -r file; do
    relpath="${file#"$CONTENT_DIR/"}"
    grep -n -i -F "$QUERY" "$file" 2>/dev/null | while IFS=: read -r lineno line; do
        section=$(head -n "$lineno" "$file" | grep '^## ' | tail -1 | sed 's/^## //' || true)
        section="${section:-top}"
        trimmed=$(echo "$line" | sed 's/^[[:space:]]*//' | cut -c1-120)
        echo "$relpath | $section | $trimmed"
    done || true
done
